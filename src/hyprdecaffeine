#!/usr/bin/env bash

# Enforce strict error handling
# -e: Exit immediately if a command exits with a non-zero status.
# -u: Treat unset variables as an error.
# -o pipefail: Return value of a pipeline is the status of the last command to exit with a non-zero status.
set -euo pipefail

# --- Configuration ---
UNIT_NAME="hyprdecaffeine"
TIMER_UNIT="${UNIT_NAME}.timer"
SERVICE_UNIT="${UNIT_NAME}.service"

# Using -i to bypass inhibitor locks (like active videos or Steam downloads)
# ensuring the computer always suspends when instructed.
SUSPEND_CMD="systemctl suspend -i"

# --- Functions ---

show_help() {
    cat <<EOF
Usage: hyprdecaffeine <command> [argument]

Commands:
  start <time>   Starts a suspend timer. Defaults to minutes if no unit is given.
                 Formats: '15', '15m', '15s', '1h', '2h30m'.
  stop           Cancels any active suspend timer.
  status         Returns the current timer status and time remaining.
  menu           Opens the interactive Rofi GUI.
  help           Shows this help message.

Examples:
  hyprdecaffeine start 30
  hyprdecaffeine status
  hyprdecaffeine menu
EOF
}

stop_timer() {
    local quiet="${1:-false}"

    # Suppress errors if the units don't exist (e.g., stopping when already stopped)
    systemctl --user stop "$TIMER_UNIT" "$SERVICE_UNIT" 2>/dev/null || true
    # Clear the failed state just in case a previous run crashed or was manually killed
    systemctl --user reset-failed "$TIMER_UNIT" "$SERVICE_UNIT" 2>/dev/null || true

    if [[ "$quiet" != "true" ]]; then
        # Send the "Off" notification
        notify-send -a "hyprdecaffeine" "󰒲 Decaffeine Off" "Suspend timer disabled"
    fi
}

start_timer() {
    local duration="$1"

    if [[ -z "$duration" ]]; then
        echo "Error: Duration not provided." >&2
        show_help
        exit 1
    fi

    # UX Improvement: Default to minutes if the user inputs only digits
    if [[ "$duration" =~ ^[0-9]+$ ]]; then
        duration="${duration}m"
    fi

    # Pass "true" so it silently resets without sending a notification
    stop_timer "true"

    # Create the transient timer using systemd-run
    # --on-active creates a monotonic timer, guaranteeing exact durations regardless of system clock syncing
    systemd-run --user \
        --unit="$UNIT_NAME" \
        --on-active="$duration" \
        --timer-property="AccuracySec=1s" \
        $SUSPEND_CMD >/dev/null 2>&1

    echo "Timer started: System will suspend in $duration."

    # Send the "Active" notification
    notify-send -a "hyprdecaffeine" "󰒲 Decaffeine Active" "Suspend scheduled: $duration"
}

get_status() {
    # 1. Verify the timer is actually running at a system level
    local state
    state=$(systemctl --user is-active "$TIMER_UNIT" 2>/dev/null || true)

    if [[ "$state" != "active" ]]; then
        echo "Inactive"
        return
    fi

    # 2. Grab the raw list-timers output.
    local timer_output
    timer_output=$(systemctl --user list-timers "$TIMER_UNIT" --no-legend 2>/dev/null || true)

    if [[ -z "$timer_output" ]]; then
        echo "Active"
        return
    fi

    # 3. Extract the absolute wall-clock timestamp systemd calculated for us.
    # systemctl list-timers format: DAY YYYY-MM-DD HH:MM:SS TZ ...
    # We use awk to grab columns 2, 3, and 4 (Date, Time, Timezone).
    local target_time
    target_time=$(echo "$timer_output" | awk '{print $2, $3, $4}')

    if [[ -z "$target_time" ]]; then
        echo "Active"
        return
    fi

    # 4. Convert that timestamp to standard UNIX epoch seconds
    local next_sec
    next_sec=$(date -d "$target_time" +%s 2>/dev/null || true)

    # Fallback if the date conversion fails for any reason
    if [[ -z "$next_sec" ]]; then
        echo "Active"
        return
    fi

    local now_sec
    now_sec=$(date +%s)
    local diff_sec=$((next_sec - now_sec))

    if ((diff_sec <= 0)); then
        echo "Suspending..."
        return
    fi

    local hours=$((diff_sec / 3600))
    local mins=$(((diff_sec % 3600) / 60))

    if ((hours > 0)); then
        echo "${hours}h ${mins}m"
    elif ((mins > 0)); then
        echo "${mins}m"
    else
        echo "<1m"
    fi
}

show_menu() {
    # Ensure Rofi is installed before trying to run the GUI
    if ! command -v rofi &>/dev/null; then
        echo "Error: rofi is not installed or not in PATH." >&2
        exit 1
    fi

    local current_status
    current_status=$(get_status)

    # Base options with Nerd Font icons
    local options="󰔛 15 min\n󰔛 30 min\n󰔛 1 hour\n󰔛 2 hours\n󰔛 Custom..."

    # Inject the separator and Cancel option at the BOTTOM if a timer is running
    if [[ "$current_status" != "Inactive" ]]; then
        options="$options\n────────────────────────\n󰤆 Turn Off ($current_status)"
    fi

    # rofi exits 1 if the user presses Escape. '|| true' prevents the script from crashing due to 'set -e'
    # Using a Nerd Font sleep icon (󰒲) for the input prompt
    local choice
    choice=$(echo -e "$options" | rofi -dmenu -i -p "󰒲 Decaffeine:" || true)

    # Handle the selection, ensuring icons are included in the match strings
    case "$choice" in
    "󰔛 15 min")
        start_timer "15m"
        ;;
    "󰔛 30 min")
        start_timer "30m"
        ;;
    "󰔛 1 hour")
        start_timer "1h"
        ;;
    "󰔛 2 hours")
        start_timer "2h"
        ;;
    "󰔛 Custom...")
        local custom_min
        custom_min=$(rofi -dmenu -p "󰔟 Enter minutes (e.g., 45):" || true)

        if [[ "$custom_min" =~ ^[0-9]+$ ]]; then
            start_timer "${custom_min}m"
        elif [[ -n "$custom_min" ]]; then
            # Sending the error as a notification instead of a blocking Rofi window
            notify-send -u critical -a "hyprdecaffeine" "Error" "Invalid input: '$custom_min'. Please enter numbers only."
        fi
        ;;
    "󰤆 Turn Off"*)
        stop_timer
        # Optionally add a system notification here, e.g.: notify-send "Hyprdecaffeine" "Timer Cancelled"
        ;;
    "──────────────")
        # The "dumb" separator was selected. Do nothing and exit cleanly.
        exit 0
        ;;
    "")
        # User pressed Escape or closed the window
        exit 0
        ;;
    *)
        notify-send -u critical -a "hyprdecaffeine" "Error" "Unknown selection."
        exit 1
        ;;
    esac
}

# --- Main Logic Routing ---

# Ensure at least one argument is provided
if [[ $# -eq 0 ]]; then
    show_help
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
start)
    start_timer "${1:-}"
    ;;
stop)
    stop_timer
    echo "Timer stopped."
    ;;
status)
    get_status
    ;;
menu)
    show_menu
    ;;
help | --help | -h)
    show_help
    ;;
*)
    echo "Error: Unknown command '$COMMAND'" >&2
    show_help
    exit 1
    ;;
esac
